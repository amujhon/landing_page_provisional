/*
 * ============================================================
 *  Apolo Landing Page — Design System
 *  Based on apolo-web (Bootstrap 5.3 + Keen Themes)
 *  info.apolo.education
 * ============================================================
 */

/* ------------------------------------------------------------ 
   1. DESIGN TOKENS
   ------------------------------------------------------------ */
:root {
    /* ---- Brand Colors ---- */
    --apolo-blue: #0C4CA8;
    --apolo-blue-light: #037CFF;
    --apolo-purple: #7b2cbf;
    --apolo-purple-dark: #3c096c;
    --apolo-purple-light: #9d4edd;
    --apolo-cyan: #48cae4;
    --apolo-cyan-dark: #0077b6;
    --apolo-orange: #fca311;
    --apolo-orange-dark: #e85d04;
    --apolo-green: #14813B;
    --apolo-green-light: #49DF7D;
    --apolo-red: #E74C3C;

    /* ---- Backgrounds (Dark — default) ---- */
    --bg-deep-space: #050B14;
    --bg-void: #0A2E4A;
    --bg-card: rgba(255, 255, 255, 0.03);
    --bg-card-hover: rgba(255, 255, 255, 0.07);

    /* ---- Text ---- */
    --text-primary: #ffffff;
    --text-secondary: #b8bcc8;
    --text-muted: #6c757d;

    /* ---- Gradients ---- */
    --gradient-primary: linear-gradient(135deg, var(--apolo-purple) 0%, var(--apolo-cyan-dark) 100%);
    --gradient-hero: linear-gradient(160deg, var(--apolo-purple-dark) 0%, var(--bg-deep-space) 50%, var(--apolo-cyan-dark) 100%);
    --gradient-btn: linear-gradient(135deg, var(--apolo-purple) 0%, var(--apolo-cyan) 100%);
    --gradient-orange: linear-gradient(135deg, var(--apolo-orange) 0%, var(--apolo-orange-dark) 100%);
    --gradient-glow: radial-gradient(circle at center, rgba(123, 44, 191, 0.15) 0%, transparent 70%);

    /* ---- Layout ---- */
    --container-width: 1200px;
    --header-height: 72px;

    /* ---- Glass / Effects ---- */
    --glass-bg: rgba(5, 11, 20, 0.7);
    --glass-border: 1px solid rgba(255, 255, 255, 0.08);
    --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.2);
    --shadow-md: 0 6px 20px rgba(0, 0, 0, 0.35);
    --shadow-lg: 0 10px 30px -10px rgba(0, 0, 0, 0.5);
    --radius-sm: 8px;
    --radius-md: 16px;
    --radius-lg: 24px;
    --radius-pill: 50px;

    /* ---- Typography ---- */
    --font-main: 'Inter', system-ui, -apple-system, sans-serif;
    --leading-tight: 1.15;
    --leading-normal: 1.6;

    /* ---- Transitions ---- */
    --ease-out: cubic-bezier(0.22, 1, 0.36, 1);
    --transition-fast: 200ms var(--ease-out);
    --transition-base: 300ms var(--ease-out);
    --transition-slow: 500ms var(--ease-out);

    /* ---- Semantic ---- */
    --bg-body: var(--bg-deep-space);
}

/* Light Mode Theme */
/* Light Mode Theme */
body.light-mode {
    --bg-body: #f5f7fa; 
    --bg-card: rgba(255, 255, 255, 0.7);
    --bg-card-hover: rgba(255, 255, 255, 1);
    --text-primary: #1a202c;
    --text-secondary: #4a5568;
    --text-muted: #718096;
    --glass-bg: rgba(255, 255, 255, 0.85);
    --glass-border: 1px solid rgba(136, 153, 166, 0.2);
    --shadow-lg: 0 10px 30px -10px rgba(0, 0, 0, 0.1);
    --icon-bg: rgba(10, 10, 20, 0.05); /* Background for icons in light mode */
}

/* Light Mode Background "Aurora" Effect */
body.light-mode {
    background-image: 
        radial-gradient(circle at 10% 20%, rgba(157, 78, 221, 0.15) 0%, transparent 60%),
        radial-gradient(circle at 90% 10%, rgba(72, 202, 228, 0.2) 0%, transparent 60%),
        radial-gradient(circle at 50% 50%, rgba(255, 255, 255, 0.8) 0%, transparent 100%);
    background-color: #f0f4f8;
}

/* Theme Toggle Button */
.theme-btn {
    background: transparent;
    border: 1px solid rgba(255,255,255,0.2);
    color: white;
    cursor: pointer;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    margin-right: 1rem;
}

.theme-btn:hover {
    background: rgba(255,255,255,0.1);
    transform: rotate(15deg);
}

/* Navbar override for Light Mode - Keep it Dark */
body.light-mode .navbar {
    background: rgba(10, 10, 20, 0.9);
    border-bottom: 1px solid rgba(255,255,255,0.1);
}

body.light-mode .navbar .logo-text,
body.light-mode .navbar .nav-link,
body.light-mode .theme-btn {
    color: white; /* Force white text */
}

/* Specific overrides for elements that need adjustments in Light Mode */
body.light-mode .pricing-item {
    background: white;
    box-shadow: 0 4px 6px rgba(0,0,0,0.05);
}

body.light-mode .contact-item {
    background: rgba(255,255,255,0.5);
}


/* 2. Reset & Base */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

html {
    scroll-behavior: smooth;
}

body {
    font-family: var(--font-main);
    background-color: var(--bg-body);
    color: var(--text-primary);
    line-height: 1.6;
    overflow-x: hidden;
    background-image: 
        radial-gradient(circle at 10% 20%, rgba(123, 44, 191, 0.15) 0%, transparent 40%),
        radial-gradient(circle at 90% 80%, rgba(72, 202, 228, 0.1) 0%, transparent 40%);
    background-attachment: fixed;
    transition: background-color 0.3s ease, color 0.3s ease;
}

body.light-mode {
    /* Background handled in variable block above */
}

a {
    text-decoration: none;
    color: inherit;
    transition: all 0.3s ease;
}

ul {
    list-style: none;
}

img, svg {
    max-width: 100%;
    vertical-align: middle;
}

/* 3. Utility Classes */
.container {
    max-width: var(--container-width);
    margin: 0 auto;
    padding: 0 1.5rem;
}

.text-gradient {
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.text-orange { color: var(--apolo-orange); }
.text-cyan { color: var(--apolo-cyan); }
.text-purple { color: var(--apolo-purple-light); }

.btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.8rem 2rem;
    border-radius: 50px;
    font-weight: 600;
    font-size: 1rem;
    cursor: pointer;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border: none;
    gap: 0.5rem;
}

.btn-primary {
    background: var(--gradient-btn);
    color: white;
    box-shadow: 0 4px 15px rgba(123, 44, 191, 0.3);
}

.btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(123, 44, 191, 0.5);
}

.btn-outline {
    background: transparent;
    border: 1px solid rgba(255,255,255,0.2);
    color: white;
}

.btn-outline:hover {
    border-color: var(--apolo-cyan);
    background: rgba(72, 202, 228, 0.1);
}

.btn-whatsapp {
    background: #25D366;
    color: white;
    box-shadow: 0 4px 15px rgba(37, 211, 102, 0.3);
}

.btn-whatsapp:hover {
    background: #20bd5a;
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(37, 211, 102, 0.5);
}

.section-padding {
    padding: 6rem 0;
}

.section-title {
    text-align: center;
    margin-bottom: 4rem;
}

.section-title h2 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
}

.section-title p {
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
    font-size: 1.1rem;
}

/* 4. Header & Navigation */
.navbar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: var(--header-height);
    background: rgba(5, 11, 20, 0.8);
    backdrop-filter: blur(12px);
    z-index: 1000;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    transition: all 0.3s ease;
}

.navbar.scrolled {
    background: rgba(5, 11, 20, 0.95);
    box-shadow: 0 10px 30px rgba(0,0,0,0.5);
}

.navbar .container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 100%;
}

.logo {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    font-weight: 700;
    font-size: 1.5rem;
    color: white;
}

.logo img, .logo svg {
    height: 40px;
    width: auto;
}

.nav-menu {
    display: flex;
    gap: 2rem;
    align-items: center;
}

.nav-link {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--text-secondary);
    position: relative;
    padding: 0.5rem 0;
}

.nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--apolo-cyan);
    transition: width 0.3s ease;
}

.nav-link:hover, .nav-link.active {
    color: white;
}

.nav-link:hover::after, .nav-link.active::after {
    width: 100%;
}

.mobile-toggle {
    display: none;
    font-size: 1.5rem;
    cursor: pointer;
}

/* 5. Hero Section */
.hero {
    padding-top: calc(var(--header-height) + 4rem);
    padding-bottom: 6rem;
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
}

/* Cosmic Background Elements */
.hero::before {
    content: '';
    position: absolute;
    top: -20%;
    right: -10%;
    width: 800px;
    height: 800px;
    background: radial-gradient(circle, rgba(123, 44, 191, 0.2) 0%, transparent 60%);
    z-index: -1;
    filter: blur(80px);
}

.hero-content {
    max-width: 650px;
    z-index: 1;
}

.hero-badge {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: rgba(72, 202, 228, 0.1);
    border: 1px solid rgba(72, 202, 228, 0.3);
    border-radius: 50px;
    color: var(--apolo-cyan);
    font-size: 0.9rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    text-transform: uppercase;
    letter-spacing: 1px;
}

.hero h1 {
    font-size: 4rem;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    font-weight: 800;
}

.hero p {
    font-size: 1.25rem;
    color: var(--text-secondary);
    margin-bottom: 2.5rem;
    line-height: 1.6;
}

.hero-buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
}

.hero-visual {
    flex: 1;
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
}

.hero-card {
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 20px;
    padding: 2rem;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    position: relative;
    animation: float 6s ease-in-out infinite;
    max-width: 500px;
}

@keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-20px); }
}

/* 6. Features / Roles Tabs */
.tabs-container {
    background: var(--bg-card);
    border: var(--glass-border);
    border-radius: 24px;
    padding: 2rem;
    max-width: 1000px;
    margin: 0 auto;
    box-shadow: var(--shadow-lg);
}

.nav-tabs {
    display: flex;
    justify-content: center;
    gap: 1rem;
    border-bottom: var(--glass-border);
    padding-bottom: 1.5rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
}

.tab-btn {
    background: transparent;
    border: none;
    color: var(--text-secondary);
    font-size: 1rem;
    font-weight: 600;
    padding: 0.5rem 1rem;
    cursor: pointer;
    border-radius: 8px;
    transition: all 0.3s ease;
}

.tab-btn:hover {
    color: var(--text-primary);
    background: var(--bg-card-hover);
}

.tab-btn.active {
    color: white; /* Always white for active tab in default purple bg */
    background: var(--apolo-purple);
}

.tab-content {
    display: none;
    animation: fadeIn 0.5s ease;
}

.tab-content.active {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
}

@keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
}

.feature-list li {
    margin-bottom: 1rem;
    display: flex;
    align-items: flex-start;
    gap: 0.8rem;
    color: var(--text-secondary);
}

.feature-list li svg {
    flex-shrink: 0;
    color: var(--apolo-cyan);
    margin-top: 4px;
}

/* 7. Modules Grid */
.modules-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
}

.module-card {
    background: var(--bg-card);
    border: var(--glass-border);
    padding: 2rem;
    border-radius: 20px;
    transition: all 0.3s ease;
    height: 100%;
}

.module-card:hover {
    background: var(--bg-card-hover);
    transform: translateY(-5px);
    border-color: var(--apolo-cyan);
}

.module-icon {
    width: 60px;
    height: 60px;
    background: linear-gradient(135deg, rgba(123,44,191,0.2), rgba(72,202,228,0.2));
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
    color: white;
}

/* Override icon color for light mode if background is too light */
body.light-mode .module-icon {
    background: linear-gradient(135deg, rgba(123,44,191,0.1), rgba(72,202,228,0.1));
    color: var(--apolo-purple);
}

.module-card h3 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    color: var(--text-primary);
}

.module-card p {
    color: var(--text-secondary);
    font-size: 0.95rem;
}

/* 8. EFIAP Section */
.efiap-section {
    background: linear-gradient(rgba(5,11,20,0.9), rgba(5,11,20,0.8)); /* Keep dark for contrast/video feel */
    border-top: 1px solid rgba(255,255,255,0.1);
    border-bottom: 1px solid rgba(255,255,255,0.1);
    text-align: center;
    position: relative;
    overflow: hidden;
}

/* Ensure EFIAP text is readable */
.efiap-section h2, .efiap-section p {
   color: white; 
   z-index: 2;
   position: relative;
}

.efiap-section .efiap-badge {
    z-index: 2;
    position: relative;
}

.efiap-badge {
    color: var(--apolo-orange);
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 1rem;
    display: block;
}

/* 9. Tech & Security (Grid) */
.tech-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    text-align: center;
}

.tech-item {
    background: var(--bg-card);
    padding: 2rem 1rem;
    border-radius: 16px;
    border: var(--glass-border);
    transition: transform 0.3s ease;
}

.tech-item:hover {
    transform: translateY(-5px);
    border-color: var(--apolo-cyan);
}

.tech-item h4 {
    margin-top: 1rem;
    margin-bottom: 0.5rem;
    color: var(--text-primary);
}

.tech-item p {
    font-size: 0.9rem;
    color: var(--text-secondary);
}

/* 10. Pricing Levels (New Layout) */
.pricing-list {
    max-width: 900px;
    margin: 3rem auto 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
}

.pricing-item {
    display: grid;
    grid-template-columns: 80px 1fr auto;
    align-items: center;
    background: var(--bg-card);
    border: var(--glass-border);
    border-radius: 20px;
    padding: 2rem;
    gap: 2rem;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
}

.pricing-item:hover {
    background: var(--bg-card-hover);
    transform: translateX(10px);
    border-color: rgba(255,255,255,0.2);
}

.pricing-item.featured {
    background: linear-gradient(90deg, rgba(60, 9, 108, 0.6) 0%, rgba(10, 10, 20, 0.8) 100%);
    border: 1px solid var(--apolo-purple);
    box-shadow: 0 10px 30px rgba(0,0,0,0.4);
}

body.light-mode .pricing-item.featured {
     background: linear-gradient(90deg, rgba(157, 78, 221, 0.1) 0%, rgba(255, 255, 255, 0.9) 100%);
     border: 1px solid var(--apolo-purple-light);
}

.pricing-item.featured::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 6px;
    background: var(--apolo-orange);
}

.pricing-icon {
    width: 80px;
    height: 80px;
    background: rgba(255,255,255,0.05);
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    color: var(--apolo-cyan);
}

body.light-mode .pricing-icon {
    background: rgba(0,0,0,0.05);
}

.pricing-content h3 {
    font-size: 1.4rem;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
}

.pricing-tag {
    font-size: 0.7rem;
    text-transform: uppercase;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    letter-spacing: 1px;
    font-weight: 700;
}

.tag-orange { background: rgba(252, 163, 17, 0.2); color: var(--apolo-orange); }
.tag-blue { background: rgba(72, 202, 228, 0.2); color: var(--apolo-cyan); }
.tag-purple { background: rgba(157, 78, 221, 0.2); color: var(--apolo-purple-light); }

.pricing-content p {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.5;
    margin-bottom: 0.5rem;
}

.pricing-conditions {
    font-size: 0.85rem;
    color: var(--text-muted);
    font-style: italic;
}

.pricing-value {
    text-align: right;
    min-width: 180px;
    padding-left: 2rem;
    border-left: 1px solid rgba(255,255,255,0.1);
}

body.light-mode .pricing-value {
    border-left: 1px solid rgba(0,0,0,0.1);
}

.price-number {
    display: block;
    font-size: 2.2rem;
    font-weight: 800;
    color: var(--text-primary);
    line-height: 1;
}

.price-period {
    display: block;
    font-size: 0.8rem;
    color: var(--text-secondary);
    margin-top: 5px;
}

/* ... (existing pricing styles) ... */

.btn-pricing {
    margin-top: 1rem;
    font-size: 0.85rem;
    padding: 0.6rem 1.4rem;
    transition: all 0.3s ease;
}

.btn-outline.btn-pricing:hover {
    background: rgba(255,255,255,0.1);
    border-color: var(--apolo-cyan);
    color: white;
    box-shadow: 0 0 15px rgba(66, 211, 244, 0.3);
}

.pricing-disclaimer {
    text-align: center;
    margin: 3rem auto 0;
    max-width: 800px;
    background: linear-gradient(145deg, rgba(255, 255, 255, 0.02) 0%, rgba(66, 211, 244, 0.05) 100%);
    padding: 2rem;
    border-radius: 16px;
    border: 1px solid rgba(66, 211, 244, 0.1);
    position: relative;
    overflow: hidden;
}

.pricing-disclaimer::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 4px;
    height: 100%;
    background: var(--apolo-cyan);
}

.pricing-disclaimer h4 {
    color: var(--text-primary); 
    font-size: 1.2rem; 
    margin-bottom: 0.8rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
}

.pricing-disclaimer p {
    font-size: 0.95rem; 
    color: var(--text-secondary); 
    line-height: 1.6;
}

.highlight-text {
    color: var(--apolo-cyan);
    font-weight: 600;
    display: block;
    margin-top: 0.5rem;
}

@media (max-width: 768px) {
    /* ... (existing media query content) ... */
    .pricing-item {
        grid-template-columns: 1fr;
        text-align: center;
        gap: 1.5rem;
        padding: 2rem 1.5rem;
    }
    /* ... */
}

/* 11. Footer */
footer {
    background: #02040a;
    padding-top: 4rem;
    border-top: 1px solid rgba(255,255,255,0.05);
}

.footer-top {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 3rem;
    margin-bottom: 3rem;
}

.footer-col h4 {
    color: white;
    margin-bottom: 1.5rem;
    font-size: 1.1rem;
}

.footer-col ul li {
    margin-bottom: 0.8rem;
}

.footer-col ul li a {
    color: var(--text-secondary);
    font-size: 0.95rem;
}

.footer-col ul li a:hover {
    color: var(--apolo-cyan);
}

.footer-bottom {
    padding: 2rem 0;
    border-top: 1px solid rgba(255,255,255,0.05);
    text-align: center;
    color: var(--text-muted);
    font-size: 0.9rem;
}

/* Responsive */
@media (max-width: 992px) {
    .hero {
        flex-direction: column;
        text-align: center;
        padding-top: 8rem;
    }
    
    .hero-content {
        margin-bottom: 4rem;
    }
    
    .hero-buttons {
        justify-content: center;
    }

    .tab-content.active {
        grid-template-columns: 1fr;
    }

    .image-block {
        order: -1;
        margin-bottom: 2rem;
    }

    .tech-grid {
        grid-template-columns: 1fr 1fr;
    }
    
    .footer-top {
        grid-template-columns: 1fr 1fr;
    }
}

@media (max-width: 768px) {
    .nav-menu {
        position: fixed;
        top: var(--header-height);
        left: 0;
        width: 100%;
        background: var(--bg-deep-space);
        flex-direction: column;
        padding: 2rem;
        border-bottom: 1px solid rgba(255,255,255,0.1);
        transform: translateY(-150%);
        transition: transform 0.3s ease;
    }
    
    .nav-menu.active {
        transform: translateY(0);
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    }
    
    .mobile-toggle {
        display: block;
    }
    
    .hero h1 {
        font-size: 2.8rem;
    }
    
    .footer-top {
        grid-template-columns: 1fr;
    }
}

/* 12. Floating Images in Tabs */
.image-block {
    display: flex;
    justify-content: center;
    align-items: center;
    animation: fadeInRight 0.8s ease;
}

@keyframes fadeInRight {
    from { opacity: 0; transform: translateX(20px); }
    to { opacity: 1; transform: translateX(0); }
}

.floating-img {
    border-radius: 16px;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.1);
    transition: transform 0.3s ease;
    animation: floatImg 6s ease-in-out infinite;
    max-height: 350px;
    object-fit: cover;
}

@keyframes floatImg {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
}

/* 13. Allies Section */
.allies-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 2rem;
    margin-top: 2rem;
}

.ally-card {
    background: var(--bg-card);
    border: var(--glass-border);
    border-radius: 12px;
    padding: 1.5rem 2rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    transition: all 0.3s ease;
    min-width: 250px;
}

.ally-card:hover {
    background: var(--bg-card-hover);
    transform: translateY(-3px);
    border-color: var(--apolo-cyan-dark);
}

.ally-icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-primary);
}

.ally-info h4 {
    color: var(--text-primary);
    font-size: 1rem;
    margin-bottom: 0.2rem;
}

.ally-info p {
    color: var(--text-secondary);
    font-size: 0.8rem;
    margin: 0;
}
